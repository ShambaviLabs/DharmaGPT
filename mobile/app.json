{
  "expo": {
    "name": "DharmaGPT",
    "slug": "dharmagpt",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAEEDA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dharmagpt.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DharmaGPT uses the microphone to transcribe your voice questions into text.",
        "NSDocumentsFolderUsageDescription": "DharmaGPT reads audio files you select for transcription."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAEEDA"
      },
      "package": "com.dharmagpt.app",
      "permissions": ["RECORD_AUDIO", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-document-picker",
        { "iCloudContainerEnvironment": "Production" }
      ]
    ],
    "scheme": "dharmagpt",
    "experiments": {
      "typedRoutes": true
    }
  }
}

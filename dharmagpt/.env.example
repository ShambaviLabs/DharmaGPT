# =============================================================================
# DharmaGPT — production configuration
# Copy to .env and fill in your API keys.
# =============================================================================

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
SARVAM_API_KEY=sk_...
PINECONE_API_KEY=...

# ── Backends ──────────────────────────────────────────────────────────────────
TRANSLATION_BACKEND=sarvam
EMBEDDING_BACKEND=openai
LLM_BACKEND=anthropic
RAG_BACKEND=pinecone

# ── Model config ──────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072
PINECONE_INDEX_NAME=dharma-gpt
PINECONE_ENVIRONMENT=us-east-1
STT_BACKEND=sarvam

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.35
MAX_CONTEXT_CHARS=6000

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,exp://192.168.1.x:8081
